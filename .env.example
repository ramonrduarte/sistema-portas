# Copie este arquivo para .env e ajuste os valores

SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
DEBUG=False
ALLOWED_HOSTS=sistema.adrofecha.com.br,localhost
CSRF_TRUSTED_ORIGINS=https://sistema.adrofecha.com.br

# Domínio para o Traefik
DOMAIN=sistema.adrofecha.com.br

# Banco de dados — aponta para o container "postgres" existente no servidor
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=portas_db
DATABASE_USER=postgres
DATABASE_PASSWORD=sua-senha-aqui
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Segurança HTTPS (habilitar em produção, atrás de proxy Traefik/nginx)
# SECURE_SSL_REDIRECT deve ficar False se o proxy já redireciona para HTTPS
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# API do Assistente GPT (necessário para orçamento por IA)
# NÃO é uma chave da OpenAI — gere o seu próprio token, ex:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# O mesmo valor deve ser cadastrado na autenticação da Action do Custom GPT.
GPT_API_TOKEN=gere-seu-proprio-token-aqui
