# Copie este arquivo para .env e ajuste os valores

SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
DEBUG=False
ALLOWED_HOSTS=sistema.adrofecha.com.br,localhost
CSRF_TRUSTED_ORIGINS=https://sistema.adrofecha.com.br

# Domínio para o Traefik
DOMAIN=sistema.adrofecha.com.br

# Banco de dados — aponta para o container "postgres" existente no servidor
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=portas_db
DATABASE_USER=postgres
DATABASE_PASSWORD=sua-senha-aqui
DATABASE_HOST=postgres
DATABASE_PORT=5432
